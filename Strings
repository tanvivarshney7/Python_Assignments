#QLC4. Mask a credit card number
# Given a 16-digit credit card number (with or without dashes), return a masked version where all digits
# except the last 4 are replaced with *. Format in groups of 4 separated by dashes.

#METHOD 1
card1 = "1234-5678-9012-3456"
last_4 = card1[-4:]
result = "****-****-****-" + last_4
print(result)

#METHOD 2
card2 = "1234-5678-9012-3456"
card2 = card2.replace("-", "")
last_4 = card2[-4:]
masked = "*" * 12 + last_4
result = "-".join([masked[0:4], masked[4:8], masked[8:12], masked[12:16]])
print(result)


#QLC5. Find the most frequent character
# Given a string, find the letter that appears most often. Ignore case and spaces. On a tie, return the
# one that appears first.
s = "Tanvi Varshney"
s = s.lower().replace(" ", "")
most_char = max(s, key = s.count)
count = s.count(most_char)
print(f"{most_char} ({count} times)")


