#22. Rename a key in a dictionary
#A dictionary has a key called 'fname'. Rename it to 'first_name' without losing its value. Use .pop() to
# remove the old key and .update() to add the new one.
#Method 1
person = {"fname": "Alice", "age": 28, "city": "London"}
removed_value = person.pop("fname")
new_person = {"first_name": removed_value}
new_person.update(person)
print(new_person)

#Method 2 (first_name added in last)
person = {"fname": "Alice", "age": 28, "city": "London"}
person.update({"first_name": person.pop("fname")})
print(person)


