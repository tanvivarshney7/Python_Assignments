#30. Find the subject with the lowest score
#Given a dictionary of exam scores, find the subject in which the student performed the worst using
# min() on .items().
#Method 1
scores = {
    "Math": 78,
    "Science": 65,
    "English": 88,
    "History": 59
}
worst_subject = min(scores, key=scores.get)
print(worst_subject)

#Method 2
scores = {
    "Math": 78,
    "Science": 65,
    "English": 88,
    "History": 59
}
worst_subject = min(scores.items(), key=lambda item: item[1])
print(worst_subject[0])
